    bool "Disable periodic indications after inactivity"
    default n

config WS2812_WIDGET_INACTIVITY_DISABLE_MS
    int "Inactivity time before periodic indications are disabled"
    default 1200000
    depends on WS2812_WIDGET_AUTO_DISABLE_AFTER_INACTIVITY

config WS2812_WIDGET_USE_EXT_POWER
    bool "Compatibility option for external power handling"
    default n

config WS2812_WIDGET_EXT_POWER_STARTUP_DELAY_MS
    int "Compatibility startup delay for external power"
    default 100
    depends on WS2812_WIDGET_USE_EXT_POWER

config WS2812_WIDGET_RESTORE_EXT_POWER_OFF
    bool "Compatibility option to restore external power off"
    default n
