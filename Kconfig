    hex "USB connected color"
    default 0x00FF00
    depends on WS2812_WIDGET_CONN_SHOW_USB

config WS2812_WIDGET_CONN_COLOR_CONNECTED
    hex "BLE connected color"
    default 0x0000FF
    depends on WS2812_WIDGET_SHOW_CONNECTIVITY

config WS2812_WIDGET_CONN_COLOR_ADVERTISING
    hex "BLE advertising color"
    default 0x00FFFF
    depends on WS2812_WIDGET_SHOW_CONNECTIVITY

