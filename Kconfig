menuconfig WS2812_WIDGET
    bool "Enable WS2812 LED widget for keyboard status overlays"
    depends on LED_STRIP
    select LED_STRIP_WS2812
    help
      Enables a WS2812 overlay indicator for battery reminders and layer changes.
      This version does not leave persistent layer colors on the strip.

if WS2812_WIDGET

config WS2812_WIDGET_USE_RGB_UNDERGLOW_OVERLAY_API
    bool "Temporarily suspend ZMK RGB underglow while showing indicators"
    depends on ZMK_RGB_UNDERGLOW
    default y
    help
      Uses zmk_rgb_underglow_overlay_suspend()/resume() so the widget can show
      smooth indicators without fighting the native RGB underglow timer and
      without saving temporary RGB off/on states to flash.

config WS2812_WIDGET_FADE_STEP_MS
    int "Fade step time in milliseconds"
    default 30
    range 5 100

config WS2812_WIDGET_PRE_FADE_MS
    int "Fade current lighting down before an indicator"
    default 600
    range 0 3000

config WS2812_WIDGET_POST_FADE_MS
    int "Fade saved lighting back after an indicator"
    default 700
    range 0 3000

config WS2812_WIDGET_INTERVAL_MS
    int "Interval between indicator pulses"
    default 250
    range 0 3000

config WS2812_WIDGET_SHOW_LAYER_CHANGE
    bool "Show temporary layer on/off indicators"
    default y

config WS2812_WIDGET_LAYER_DEBOUNCE_MS
    int "Layer change debounce in milliseconds"
    default 30
    range 0 1000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_INDICATOR_MASK
    hex "Layer mask for layer indicators"
    default 0xFFFFFFFE
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE
    help
      Bit mask of layers that should trigger the indicator.
      Default 0xFFFFFFFE means all layers except layer 0.

config WS2812_WIDGET_LAYER_ON_COLOR
    hex "Layer enabled indicator color"
    default 0xFFFFFF
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_OFF_COLOR
    hex "Layer disabled indicator color"
    default 0xFF0000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_BLINK_MS
    int "Legacy layer blink duration in milliseconds"
    default 100
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE
    help
      Kept for compatibility with old configs. The new smooth overlay uses
      WS2812_WIDGET_LAYER_HOLD_MS and fade timings instead.

config WS2812_WIDGET_LAYER_HOLD_MS
    int "Layer indicator full-bright hold time in milliseconds"
    default 1000
    range 100 5000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_REPEAT_COUNT
    int "Layer indicator pulse count"
    default 1
    range 1 10
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_SHOW_LAYER_COLORS
    bool "Legacy persistent layer colors"
    default n
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE
    help
      Kept only so old configs do not break. This overlay implementation does
      not use persistent layer colors, because persistent colors conflict with
      normal RGB underglow.

config WS2812_WIDGET_LAYER_COLOR
    hex "Legacy layer change color"
    default 0xFFFFFF
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_0_COLOR
    hex "Legacy layer 0 color"
    default 0x000000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_1_COLOR
    hex "Legacy layer 1 color"
    default 0xFF0000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_2_COLOR
    hex "Legacy layer 2 color"
    default 0x00FF00
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_3_COLOR
    hex "Legacy layer 3 color"
    default 0xFFFF00
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_4_COLOR
    hex "Legacy layer 4 color"
    default 0x0000FF
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_5_COLOR
    hex "Legacy layer 5 color"
    default 0xFF00FF
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_6_COLOR
    hex "Legacy layer 6 color"
    default 0x00FFFF
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_SHOW_BATTERY
    bool "Show battery indicators"
    depends on ZMK_BATTERY_REPORTING
    default y

config WS2812_WIDGET_SHOW_BATTERY_ON_START
    bool "Show battery indicator on startup"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default n

config WS2812_WIDGET_BATTERY_REMINDER
    bool "Show periodic red battery reminder"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default y

config WS2812_WIDGET_BATTERY_REMINDER_INTERVAL_MS
    int "Battery reminder interval in milliseconds"
    depends on WS2812_WIDGET_BATTERY_REMINDER
    default 180000
    range 10000 3600000

config WS2812_WIDGET_BATTERY_REMINDER_COLOR
    hex "Battery reminder color"
    depends on WS2812_WIDGET_BATTERY_REMINDER
    default 0xFF0000

config WS2812_WIDGET_BATTERY_REMINDER_REPEAT_COUNT
    int "Battery reminder pulse count"
    depends on WS2812_WIDGET_BATTERY_REMINDER
    default 3
    range 1 10

config WS2812_WIDGET_BATTERY_HOLD_MS
    int "Battery reminder full-bright hold time in milliseconds"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default 700
    range 100 5000

config WS2812_WIDGET_BATTERY_BLINK_MS
    int "Legacy battery blink duration in milliseconds"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default 200
    help
      Kept for compatibility with old configs. The new smooth overlay uses
      WS2812_WIDGET_BATTERY_HOLD_MS and fade timings instead.

config WS2812_WIDGET_BATTERY_LEVEL_HIGH
    int "High battery level percentage"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default 80
    range 0 100

config WS2812_WIDGET_BATTERY_LEVEL_LOW
    int "Low battery level percentage"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default 20
    range 0 100

config WS2812_WIDGET_BATTERY_LEVEL_CRITICAL
    int "Critical battery level percentage"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default 5
    range 0 100

config WS2812_WIDGET_BATTERY_CRITICAL_REPEAT_COUNT
    int "Critical battery warning pulse count"
    depends on WS2812_WIDGET_SHOW_BATTERY
    default 5
    range 1 10

config WS2812_WIDGET_SHOW_CONNECTIVITY
    bool "Show connectivity indicator"
    depends on ZMK_BLE
    default n

config WS2812_WIDGET_CONN_SHOW_USB
    bool "Show USB connection status"
    depends on ZMK_USB && WS2812_WIDGET_SHOW_CONNECTIVITY
    default n

config WS2812_WIDGET_CONN_BLINK_MS
    int "Legacy connectivity blink duration in milliseconds"
    default 150
    depends on WS2812_WIDGET_SHOW_CONNECTIVITY

