menuconfig WS2812_WIDGET
    bool "Enable WS2812 LED widget for keyboard status overlays"
    depends on LED_STRIP
    select LED_STRIP_WS2812
    help
      Enables a WS2812 overlay indicator for battery reminders and layer changes.
      This implementation does not leave persistent layer colors on the strip.

if WS2812_WIDGET

config WS2812_WIDGET_ENABLED_ON_START
    bool "Enable WS2812 widget on boot"
    default y

config WS2812_WIDGET_INTERVAL_MS
    int "Generic interval between indication pulses in milliseconds"
    default 200
    range 0 5000

config WS2812_WIDGET_FADE_STEP_MS
    int "Fade step time in milliseconds"
    default 30
    range 5 100

config WS2812_WIDGET_PRE_FADE_MS
    int "Fade current lighting down before an indicator"
    default 600
    range 0 3000

config WS2812_WIDGET_POST_FADE_MS
    int "Fade indicator out before restoring lighting"
    default 600
    range 0 3000

config WS2812_WIDGET_AUTO_DISABLE_AFTER_INACTIVITY
    bool "Disable periodic indications after inactivity"
    default n

config WS2812_WIDGET_INACTIVITY_DISABLE_MS
    int "Inactivity time before periodic indications are disabled"
    default 1200000
    depends on WS2812_WIDGET_AUTO_DISABLE_AFTER_INACTIVITY

config WS2812_WIDGET_PAUSE_RGB_UNDERGLOW
    bool "Temporarily pause ZMK RGB underglow while showing indicators"
    depends on ZMK_RGB_UNDERGLOW
    default y
    help
      Driver-only workaround. Uses public zmk_rgb_underglow_get_state/off/on()
      instead of patching ZMK core.

config WS2812_WIDGET_UNDERGLOW_OFF_DELAY_MS
    int "Delay after turning off RGB underglow before widget indication"
    default 120
    depends on WS2812_WIDGET_PAUSE_RGB_UNDERGLOW

config WS2812_WIDGET_UNDERGLOW_RESTORE_DELAY_MS
    int "Delay before restoring RGB underglow after widget indication"
    default 80
    depends on WS2812_WIDGET_PAUSE_RGB_UNDERGLOW

config WS2812_WIDGET_USE_RGB_UNDERGLOW_OVERLAY_API
    bool "Compatibility option: use patched RGB underglow overlay API"
    depends on ZMK_RGB_UNDERGLOW
    default n
    help
      Kept only so old configs do not fail. This driver-only version does not use
      zmk_rgb_underglow_overlay_suspend()/resume().

config WS2812_WIDGET_USE_EXT_POWER
    bool "Temporarily enable external power for WS2812 indications"
    depends on ZMK_EXT_POWER
    default y if ZMK_EXT_POWER
    help
      Enable external power before writing indicator colors to the WS2812 strip.
      This is required when RGB underglow is OFF and the LED VCC rail is also OFF.

config WS2812_WIDGET_EXT_POWER_STARTUP_DELAY_MS
    int "Delay after enabling external power before writing LEDs"
    default 100
    range 0 1000
    depends on WS2812_WIDGET_USE_EXT_POWER

config WS2812_WIDGET_RESTORE_EXT_POWER_OFF
    bool "Restore external power to OFF after indication if it was OFF before"
    default y
    depends on WS2812_WIDGET_USE_EXT_POWER

# ---------------------------------------------------------------------
# Layer indication
# ---------------------------------------------------------------------

config WS2812_WIDGET_SHOW_LAYER_CHANGE
    bool "Show temporary layer on/off indicators"
    default y

config WS2812_WIDGET_SHOW_LAYER_COLORS
    bool "Legacy persistent layer colors"
    default n
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE
    help
      Kept only for compatibility. This patched driver does not use persistent
      layer colors, because persistent colors conflict with normal underglow.

config WS2812_WIDGET_LAYER_DEBOUNCE_MS
    int "Layer change debounce in milliseconds"
    default 30
    range 0 1000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_INDICATOR_MASK
    hex "Layer mask for layer indicators"
    default 0xFFFFFFFE
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE
    help
      Bit mask of layers that should trigger the indicator.
      Default 0xFFFFFFFE means all layers except layer 0.

config WS2812_WIDGET_LAYER_TRIGGER_0
    int "Layer number that should trigger indication 0"
    default -1
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_TRIGGER_1
    int "Layer number that should trigger indication 1"
    default -1
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_TRIGGER_2
    int "Layer number that should trigger indication 2"
    default -1
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_TRIGGER_3
    int "Layer number that should trigger indication 3"
    default -1
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_COLOR_ON
    hex "Layer enabled indicator color"
    default 0xFFFFFF
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_COLOR_OFF
    hex "Layer disabled indicator color"
    default 0xFF0000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_COLOR_MANUAL
    hex "Manual layer indicator color"
    default 0xFFFFFF
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_FADE_ENABLE
    bool "Fade layer indications"
    default y
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_FADE_STEPS
    int "Compatibility fade step count for layer indication"
    default 20
    range 1 100
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_FADE_IN_MS
    int "Layer indication fade-in time in milliseconds"
    default 600
    range 0 3000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_HOLD_MS
    int "Layer indicator full-bright hold time in milliseconds"
    default 1000
    range 100 5000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_FADE_OUT_MS
    int "Layer indication fade-out time in milliseconds"
    default 600
    range 0 3000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_REPEAT_COUNT
    int "Layer indicator pulse count"
    default 1
    range 1 10
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_BLINK_REPEAT
    int "Compatibility layer blink repeat count"
    default 1
    range 1 10
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_BLINK_PAUSE_MS
    int "Pause between layer blinks in milliseconds"
    default 1000
    range 0 5000
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_LAYER_BLINK_MS
    int "Legacy layer blink duration in milliseconds"
    default 100
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE
    help
      Kept for compatibility with old configs.

config WS2812_WIDGET_LAYER_COLOR
    hex "Legacy layer change color"
