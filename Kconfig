# Smooth blink / fade
# ===============================

config WS2812_WIDGET_LAYER_FADE_ENABLE
    bool "Use smooth fade for layer indication"
    default y

config WS2812_WIDGET_LAYER_FADE_STEPS
    int "Layer fade steps"
    default 10
    depends on WS2812_WIDGET_LAYER_FADE_ENABLE


