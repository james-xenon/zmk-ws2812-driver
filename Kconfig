    default 30
    depends on WS2812_WIDGET_SHOW_LAYER_CHANGE

config WS2812_WIDGET_BATTERY_COOLDOWN_AFTER_LAYER_MS
    int "Do not show battery warning immediately after layer indication"
    default 15000

config WS2812_WIDGET_SHOW_LAYER_COLORS
    bool "Show persistent layer colors"
    default n
    help
      Compatibility option only. This patched version does not keep LEDs on for layers.


