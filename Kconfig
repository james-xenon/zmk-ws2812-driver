config WS2812_WIDGET
    bool "Enable WS2812 LED widget for showing battery/layer status"
    depends on LED_STRIP
    help
      Enable WS2812 RGB LED widget for keyboard status indication.

if WS2812_WIDGET

config WS2812_WIDGET_COLOR_RED
    hex "Red color value"
    default 0xFF0000

config WS2812_WIDGET_COLOR_GREEN
    hex "Green color value"
    default 0x00FF00

config WS2812_WIDGET_COLOR_BLUE
    hex "Blue color value"
    default 0x0000FF

config WS2812_WIDGET_COLOR_YELLOW
    hex "Yellow color value"
    default 0xFFFF00

config WS2812_WIDGET_COLOR_MAGENTA
    hex "Magenta color value"
    default 0xFF00FF

config WS2812_WIDGET_COLOR_CYAN
    hex "Cyan color value"
    default 0x00FFFF

config WS2812_WIDGET_COLOR_WHITE
    hex "White color value"
    default 0xFFFFFF

config WS2812_WIDGET_COLOR_OFF
    hex "Off/black color value"
    default 0x000000


# ===============================
# Manual enable/disable
# ===============================

config WS2812_WIDGET_ENABLED_ON_START
    bool "Enable WS2812 indication on boot"
    default y

config WS2812_WIDGET_AUTO_DISABLE_AFTER_INACTIVITY
    bool "Suppress WS2812 indication after keyboard inactivity"
    default y

config WS2812_WIDGET_INACTIVITY_DISABLE_MS
    int "Milliseconds of keyboard inactivity before WS2812 indication is suppressed"
    default 1200000
    depends on WS2812_WIDGET_AUTO_DISABLE_AFTER_INACTIVITY


# ===============================
# External power handling
# ===============================

config WS2812_WIDGET_USE_EXT_POWER
    bool "Enable external power automatically before blinking"
    depends on ZMK_EXT_POWER
    default y

config WS2812_WIDGET_EXT_POWER_STARTUP_DELAY_MS
    int "Delay after enabling external power before writing LEDs"
    depends on WS2812_WIDGET_USE_EXT_POWER
    default 100

config WS2812_WIDGET_RESTORE_EXT_POWER_OFF
    bool "Restore external power to off if it was off before blink"
    depends on WS2812_WIDGET_USE_EXT_POWER
    default y


# ===============================
# RGB underglow conflict handling
# ===============================

config WS2812_WIDGET_PAUSE_RGB_UNDERGLOW
    bool "Temporarily pause ZMK RGB underglow while blinking"
    depends on ZMK_RGB_UNDERGLOW
    default y

config WS2812_WIDGET_UNDERGLOW_OFF_DELAY_MS
    int "Delay after turning ZMK RGB underglow off before blinking"
    depends on WS2812_WIDGET_PAUSE_RGB_UNDERGLOW
    default 120

config WS2812_WIDGET_UNDERGLOW_RESTORE_DELAY_MS
    int "Delay after restoring ZMK RGB underglow"
    depends on WS2812_WIDGET_PAUSE_RGB_UNDERGLOW
    default 80


