config WS2812_WIDGET_PAUSE_RGB_UNDERGLOW
    bool "Temporarily turn off ZMK RGB underglow while showing widget indication"
    depends on ZMK_RGB_UNDERGLOW
    default y
    help
      Driver-only workaround. This uses public zmk_rgb_underglow_off/on calls
      to stop normal underglow from repainting the strip during indication.
      ZMK debounces settings saves, so short off/on sequences should usually
      end with the original on state being saved.

config WS2812_WIDGET_UNDERGLOW_OFF_DELAY_MS
    int "Delay after turning off RGB underglow before widget indication"
    default 120
    depends on WS2812_WIDGET_PAUSE_RGB_UNDERGLOW

config WS2812_WIDGET_UNDERGLOW_RESTORE_DELAY_MS
    int "Delay before restoring RGB underglow after widget indication"
    default 80
    depends on WS2812_WIDGET_PAUSE_RGB_UNDERGLOW

